{
  "_comment": "Copy to heartbeat-jobs.json and customize. heartbeat.py loads jobs from heartbeat-jobs.json at startup.",
  "_schema": {
    "id": "unique identifier",
    "name": "human-readable name",
    "schedule": "cron expression (minute hour day-of-month month day-of-week)",
    "type": "script | http",
    "command": "shell command to run (for type=script)",
    "enabled": "true | false",
    "notify": "send Telegram notification on every run (true) or only on error (false)",
    "notify_on_error": "send notification when command exits non-zero",
    "self_notify": "send notification to the CB Bot's own chat",
    "timeout": "max execution time in seconds"
  },
  "jobs": [
    {
      "id": "github-watch",
      "name": "GitHub Repo Watch",
      "schedule": "17 10 * * 1",
      "type": "script",
      "command": "python3 ~/.claude-bridge/scripts/github-watch.py",
      "enabled": true,
      "notify": false,
      "notify_on_error": true,
      "self_notify": true,
      "timeout": 120
    },
    {
      "id": "system-health",
      "name": "System Health",
      "schedule": "0 */6 * * *",
      "type": "script",
      "command": "python3 ~/.claude-bridge/scripts/system-health.py",
      "enabled": true,
      "notify": true,
      "timeout": 30
    },
    {
      "id": "cb-watchdog",
      "name": "CB Liveness Check",
      "schedule": "*/5 * * * *",
      "type": "script",
      "command": "python3 ~/.claude-bridge/scripts/cb-watchdog.py",
      "enabled": true,
      "notify": false,
      "notify_on_error": true,
      "self_notify": true,
      "timeout": 30
    }
  ]
}
